# Copy this file to .env and fill in your real key. Never commit .env.

# Google Gemini API key. Required from Phase 3 onward; unused in Phase 1-2.
GEMINI_API_KEY=

# Model IDs are config, not code, because model generations change fast.
# Verify current model IDs and pricing at ai.google.dev before Phase 3.
IMAGE_MODEL=gemini-3.1-flash-image
TEXT_MODEL=gemini-2.5-flash
